VITE_API_URL=http://localhost:3000
# Salin file ini menjadi `.env` di folder yang sama dengan `package.json`, lalu isi baris di bawah.
# Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID → Web application
# Authorized JavaScript origins: http://localhost:5173 (sesuaikan port Vite Anda)
# Setelah mengubah .env: stop dev server, jalankan lagi `pnpm dev` atau `npm run dev`.
VITE_GOOGLE_CLIENT_ID=
