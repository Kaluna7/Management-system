generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  googleSub   String?  @unique
  email       String?  @unique
  displayName String?
  /** buyers | finance | buyers_admin | finance_admin; null until role is set */
  role        String?
  /** bcrypt hash; set when user finishes onboarding (username + password). */
  passwordHash String?
  /** SHA-256 hash of role verification code (Google login → choose department). */
  roleVerifyCodeHash String?
  roleVerifyExpires  DateTime?
  /** When a verification email was last sent (any path). Used for anti-spam cooldown. */
  roleVerifyLastSentAt  DateTime?
  /** How many times the user used "Resend" (force). Drives 30+ min rules. */
  roleVerifyResendCount Int @default(0)
  /**
   * 0 = default (1 min; >3 resends → 30 min). 2 = user failed code after heavy resend → 1 h lock.
   */
  roleVerifyCooldownTier Int @default(0)
  /** Forgot-password flow (account settings). */
  passwordResetCodeHash       String?
  passwordResetExpires        DateTime?
  passwordResetLastSentAt     DateTime?
  passwordResetResendCount    Int       @default(0)
  passwordResetCooldownTier   Int       @default(0)
  /** Set after code verify; allows POST confirm within window. */
  passwordResetVerifiedUntil  DateTime?
  /** Preset avatar id "01"–"15", or null when using custom upload. */
  avatarPreset          String?
  /** Stored file name under storage/profiles/{userId}/ */
  profileImageFileName  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/** Master vendor list (code + name). Populate via SQL/Prisma Studio — not seeded in app. */
model Vendor {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/** Saved memo lines for finance invoice form (dropdown + add new). */
model InvoiceMemoOption {
  id        String   @id @default(cuid())
  label     String
  /** rebate_bonus_tier | custom — rebate line uses current year on print. */
  template  String   @default("custom")
  /** buyers | finance — dropdown scoped per portal department */
  createdByRole String @default("finance")
  sortOrder Int      @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([label, template, createdByRole])
}

/** Saved bank transfer details for finance invoice form (dropdown + add new). */
model InvoiceBankAccount {
  id              String   @id @default(cuid())
  beneficiaryName String
  bankName        String
  bankBranch      String
  accountNo       String
  /** buyers | finance */
  createdByRole   String @default("finance")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([beneficiaryName, bankName, bankBranch, accountNo, createdByRole])
}

/** Saved invoice signatories: job title + person name (dropdown + add new). */
model InvoiceSigner {
  id            String   @id @default(cuid())
  title         String
  name          String
  createdByRole String @default("finance")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([title, name, createdByRole])
}

model BuyerRecord {
  id                  String   @id @default(cuid())
  vendorCode          String
  vendorName          String
  incomeType          String
  agreementFileName   String
  /** Display names for up to 5 agreement files (buyers). */
  agreementFileNames  Json?
  amount              Float
  periodStart         DateTime
  periodEnd           DateTime
  description         String
  createdBy           String
  /** true when created via admin-system (not management portal). */
  createdByAdmin      Boolean  @default(false)
  /** buyers | finance | buyers_admin | finance_admin */
  createdByRole       String?
  createdAt           DateTime @default(now())
  status              String   @default("created")
  invoiceReceived     Boolean  @default(false)
  invoice             Json?
  generatedBy         String?
  generatedAt         DateTime?
  stampedPaperFileName String?
  archivedAt          DateTime?
  publishedAt         DateTime?
  /** Set when deadline reminder email was sent to buyers (once per record, MVP). */
  buyerDeadlineNotifiedAt   DateTime?
  /** Set when deadline reminder email was sent to finance (once per record, MVP). */
  financeDeadlineNotifiedAt DateTime?
  /** null | pending | denied — buyer asks finance to unlock edits after invoice is in task. */
  buyerEditRequestStatus  String?
  buyerEditRequestedAt    DateTime?
  buyerEditRequestedBy    String?
  buyerEditResolvedAt     DateTime?
  buyerEditResolvedBy     String?
  updatedAt           DateTime @updatedAt
}
