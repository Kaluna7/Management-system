PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ms?schema=public"

# Google Sign-In (OAuth 2.0 Web Client ID dari Google Cloud Console) — sama dengan VITE_GOOGLE_CLIENT_ID di frontend
GOOGLE_CLIENT_ID=
# Secret untuk JWT sesi aplikasi (string acak panjang, jangan commit nilai asli)
JWT_SECRET=

# =============================================================================
# Email — Brevo
# REST API: BREVO_API_KEY (v3, xkeysib-…) — https://app.brevo.com/settings/keys/api
# (Di UI bisa tertulis "API / MCP" — itu tetap key v3; bisa juga pakai BREVO_MCP_KEY.)
#
# Bukan contoh "EmailCampaignsApi" di dokumentasi Brevo — itu untuk kampanye ke contact list.
# Aplikasi ini pakai Transactional API: POST /v3/smtp/email (sudah di mailer.js).
#
# Widget "Emails X left" di dashboard sering menghitung kuota marketing/kampanye — kiriman
# transaksional (API ini) cek di Brevo → Transactional → Logs / Statistics, bukan angka itu saja.
#
# Jika "IP blocking for API" aktif di Brevo, hanya IP terdaftar yang boleh memanggil API.
# Tambahkan IP publik PC/server yang menjalankan backend, atau matikan untuk dev lokal.
# https://account.brevo.com/security/authorised_ips
#
# SMTP di bawah = fallback bila API gagal; SMTP bisa punya pembatasan IP terpisah (error 525).
# =============================================================================
BREVO_API_KEY=
# Optional: coba SMTP dulu lalu API (default: API dulu). BREVO_TRY_SMTP_FIRST=true
# Pengirim (harus verified di Brevo). Sama format SMTP_FROM atau hanya email:
# SMTP_FROM="WHSmith <noreply@domain.com>"
# BREVO_SENDER_EMAIL=noreply@domain.com
SMTP_FROM=

# =============================================================================
# Alternatif: SMTP relay (bisa kena 525 Unauthorized IP jika IP tidak di-whitelist)
# =============================================================================
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Penerima reminder deadline (koma)
NOTIFY_EMAIL_BUYERS=buyer1@example.com
NOTIFY_EMAIL_FINANCE=finance1@example.com

# Optional: POST /api/notifications/run-deadline-reminders header x-cron-secret
CRON_SECRET=
DEADLINE_CRON=0 8 * * *
DEADLINE_CRON_TZ=Asia/Jakarta
DISABLE_DEADLINE_CRON=false
DEADLINE_REMINDER_TZ=Asia/Jakarta
