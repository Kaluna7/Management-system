PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ms?schema=public"

# Google Sign-In (OAuth 2.0 Web Client ID dari Google Cloud Console) — sama dengan VITE_GOOGLE_CLIENT_ID di frontend
GOOGLE_CLIENT_ID=
# Secret untuk JWT sesi aplikasi (string acak panjang, jangan commit nilai asli)
JWT_SECRET=

# Dev only: nonaktifkan countdown Resend (email tetap dikirim). Jangan true di production.
# ROLE_VERIFY_NO_COOLDOWN=true

# =============================================================================
# Email — Hostinger SMTP (recommended)
# Hostinger hPanel → Email → buat mailbox → gunakan alamat & password di bawah.
# SMTP_FROM harus memakai alamat mailbox yang sama dengan SMTP_USER.
#
# Port 465 (SSL): SMTP_PORT=465, SMTP_SECURE=true
# Port 587 (TLS): SMTP_PORT=587, SMTP_SECURE=false  ← default di bawah
# =============================================================================
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
# Pakai tanda kutip jika password ada # spasi atau karakter khusus
SMTP_PASS=
SMTP_FROM="Finly <noreply@yourdomain.com>"

# Optional: Brevo REST API (kosongkan jika hanya pakai Hostinger SMTP)
BREVO_API_KEY=

# Penerima reminder deadline (koma) — opsional jika user di DB sudah punya email
NOTIFY_EMAIL_BUYERS=
NOTIFY_EMAIL_FINANCE=

# Optional: POST /api/notifications/run-deadline-reminders header x-cron-secret
CRON_SECRET=
DEADLINE_CRON=0 8 * * *
DEADLINE_CRON_TZ=Asia/Jakarta
DISABLE_DEADLINE_CRON=false
DEADLINE_REMINDER_TZ=Asia/Jakarta
