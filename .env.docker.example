# Copy to repo root as `.env` before Jenkins deploy or `docker compose up`
# cp .env.docker.example .env

# --- Docker / Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=ms
FRONTEND_PORT=8080

# --- Frontend build (management-system) ---
# Leave empty: browser calls same host; nginx proxies /api to backend
VITE_API_URL=
VITE_GOOGLE_CLIENT_ID=

# --- Backend (back-end) ---
JWT_SECRET=change-me-long-random-string
GOOGLE_CLIENT_ID=

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Finly <noreply@yourdomain.com>"

NOTIFY_EMAIL_BUYERS=
NOTIFY_EMAIL_FINANCE=
CRON_SECRET=
DEADLINE_CRON=0 8 * * *
DEADLINE_CRON_TZ=Asia/Jakarta
DISABLE_DEADLINE_CRON=false
